source 'https://rubygems.org'

# Local development uses modern Jekyll 4 (works on current Ruby). GitHub Pages
# still builds the live site server-side with its own pinned github-pages stack,
# independent of this file.
gem 'jekyll', '~> 4.3'

group :jekyll_plugins do
  gem 'jekyll-feed'
  gem 'jekyll-gist'
  gem 'jekyll-paginate'
  gem 'jekyll-sitemap'
  gem 'jekyll-redirect-from'
  gem 'jemoji'
  gem 'jekyll-include-cache'
  gem 'webrick', '~> 1.8'
end
